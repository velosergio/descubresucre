# Base de datos (MySQL, p. ej. XAMPP)
DATABASE_URL="mysql://root:@localhost:3306/descubresucre"

# Auth.js / NextAuth — genera uno seguro: `npx auth secret` o `openssl rand -base64 32`
AUTH_SECRET=""

# URL pública de la app (producción). En local suele inferirse.
# AUTH_URL="http://localhost:3000"

# OAuth Google (opcional). En Google Cloud Console añade redirect:
# {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Primer usuario administrador (después de migraciones y seed de roles):
# npm run admin:create
# (te pedirá correo, contraseña y confirmación en la terminal)

# Registro público en /register: rol "editor" y estado PENDING hasta aprobación en /admin/users.
# Tras aprobar, el usuario puede entrar a /admin. Rechazados ven /cuenta/rechazada.
# Google OAuth: mismo callback /api/auth/callback/google (nuevas cuentas también quedan PENDING).
